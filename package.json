{
  "name": "mcp-intent-firewall",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "turbo run dev --filter=./apps/api --filter=./apps/web",
    "dev:api": "turbo run dev --filter=./apps/api",
    "dev:web": "turbo run dev --filter=./apps/web",
    "build": "turbo run build",
    "custom:mcp": "turbo run start --filter=custom-mcp",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "bun apps/api/src/db/seed.ts",
    "start:railway": "bun run prisma:deploy && bun --filter api start",
    "test": "bun test",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@upstash/context7-mcp": "3.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "dotenv": "^17.4.2",
    "prisma": "^7.0.0",
    "turbo": "^2.9.16",
    "typescript": "^5"
  }
}
