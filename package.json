{
  "name": "mcp-intent-firewall",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter api dev",
    "dev:api": "bun --filter api dev",
    "dev:web": "bun --filter web dev",
    "custom:mcp": "bun --filter custom-mcp start",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
